NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
DATABASE_URL="postgres://postgres.xxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# Gunakan Upstash Redis URL di sini
REDIS_URL="rediss://default:your-password@your-upstash-endpoint.upstash.io:6379"

# AI Keys
NVIDIA_API_KEY="nvapi-..."
SUMOPOD_API_KEY="sk-..."                  # https://sumopod.com/dashboard/ai/quickstart
GOOGLE_API_KEY="..."                      # https://aistudio.google.com/apikey
ANTHROPIC_API_KEY="sk-ant-..."            # optional, for Claude

# Email Service (Resend)
RESEND_API_KEY="re_..."                   # https://resend.com/api-keys
RESEND_FROM_EMAIL="hello@yourdomain.com"  # Must be a verified domain in Resend

# Model overrides per tier (optional — defaults: fast=8b, standard=70b, heavy=claude)
# Supports provider:model syntax: nvidia:meta/llama-3.1-8b, google:gemma-4-31b-it, sumopod:gpt-4o, claude-sonnet-4-6
# AI_FAST_MODEL="google:gemma-4-26b-a4b-it"
# AI_STANDARD_MODEL="nvidia:meta/llama-3.1-70b-instruct"
# AI_HEAVY_MODEL="claude-sonnet-4-6"
