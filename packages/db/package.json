{
  "name": "@repo/db",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "push": "dotenv -e ../../.env -- drizzle-kit push",
    "studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "seed": "tsx src/seed/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@repo/typescript-config": "workspace:*",
    "dotenv-cli": "^11.0.0"
  }
}
